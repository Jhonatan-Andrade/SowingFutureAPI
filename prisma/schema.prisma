
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User {
  id           String     @id @default(uuid())
  name         String     @unique
  email        String     @unique
  password     String     @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  accountingRecords AccountingRecord[]
  goals Goals[]
  @@map("user")
}
model AccountingRecord {
  id            String     @id @default(uuid())
  title         String     
  value         Decimal @db.Decimal(8, 2)     
  type          String     
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userId        String     
  user          User       @relation(fields: [userId], references: [id])
  @@map("accountingRecords")
}
model Goals {
  id            String     @id @default(uuid())
  title         String     
  targetValue   Decimal @db.Decimal(8, 2)     
  currentValue  Decimal @db.Decimal(8, 2)
  date          String    
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  userId        String     
  user          User       @relation(fields: [userId], references: [id])
  @@map("goals")
}